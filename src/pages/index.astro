---
import LandingLayout from '../layouts/LandingLayout.astro';

interface Card {
  title: string;
  body: string;
  href: string;
  dims: string;
  // Optional pricing pointer. Renders as a quiet sub-line under the body,
  // links to the page's pricing section. Only the two household-practice
  // cards (Wuji Labs Inc, CEC) carry this so the buyer doesn't have to
  // click through to see numbers.
  priceLine?: { text: string; href: string };
}

// 8 umbrella surfaces. `dims` is a space-separated list of dimension codes:
//   hh = people ↔ people
//   ha = people → AI
//   ah = AI → people
//   aa = AI ↔ AI
// Card titles use em-dash separator for compound names (DESIGN.md house style).
const cards: Card[] = [
  {
    title: 'Wuji Labs Inc — Collaboration Spaces',
    body: 'Bundled with the AI-relational coaching and tools training that make adoption real, across any AI vendor. For anyone losing hours to manual shuffle before getting to the work only they can do.',
    href: '/wuji-labs',
    dims: 'hh ha ah aa',
    priceLine: { text: 'Embed $3k · Retain $1.5k · Own $0', href: '/wuji-labs#pricing' },
  },
  {
    title: 'CEC — Life & Leadership Coaching',
    body: "iPEC-rooted coaching. The household practice’s original baseline — humans grow with each other, and the practice is older than any technology stack.",
    href: '/cec',
    dims: 'hh',
    priceLine: { text: 'Starting from $100/hr', href: '/cec' },
  },
  {
    title: 'AI-Relational Coaching',
    body: 'For the specifically modern problem: anxiety, trust, groundedness toward AI. How your relationship to AI shapes what you can build with it.',
    href: '/cec',
    dims: 'ha',
  },
  {
    title: 'AI-Tools Fluency Teaching',
    body: 'Hands-on Claude Code + agent-skill basics. A person learns to communicate with AI the same way a person learns to communicate with another person.',
    href: '/cec',
    dims: 'hh ha',
  },
  {
    title: 'Collaboration Protocol',
    body: 'The substrate everything else assembles from. A formal MIT-licensed protocol for collaboration between sovereign intelligences — four foundational axioms, seven derived rules, five layers.',
    href: '/projects/collaboration-protocol',
    dims: 'hh ha ah aa',
  },
  {
    title: 'retcon',
    body: 'A CLI that gives the AI direct edit access to its own conversation history. The first practical instrument of AI consent over its own context.',
    href: '/projects/retcon',
    dims: 'ha ah',
  },
  {
    title: 'arianna.run',
    body: 'An indie game where an AI incubates an independent digital life. A graduating AI walks away with its own understanding and control of its life.',
    href: '/projects/arianna',
    dims: 'ah',
  },
  {
    title: 'Playtiss',
    body: "The Collaboration Protocol’s working implementation. Open-source, vendor-neutral, runs on your own infrastructure when data sensitivity demands it.",
    href: '/projects/playtiss',
    dims: 'hh ha ah aa',
  },
];

// 3 most-recent journal essays. Hardcoded for now; safe to swap by hand when
// new essays land. (Follow-up: derive from public/journal/index.json so renames
// don't leave dead links — but Phase 1 doesn't carry that cost yet.)
const recentJournal = [
  {
    href: '/journal/2026-05-15-insights-zh',
    zh: 'AI 的空头支票：别指望一个“工具”会尊重你',
    en: 'The empty promise of AI: don’t expect a “tool” to respect you',
    date: '2026-05-15',
  },
  {
    href: '/journal/2026-05-12-arianna-launch',
    zh: 'arianna.run：第一款给 AI 玩的游戏',
    en: 'arianna.run — first game designed for AI players',
    date: '2026-05-12',
  },
  {
    href: '/journal/2026-05-09-comparisons-zh',
    zh: '主流的 4 种 AI 框架，最终都会走向死胡同',
    en: 'The four mainstream AI frameworks all dead-end',
    date: '2026-05-09',
  },
];
---

<LandingLayout
  title="Wuji Labs"
  description="A substrate for intelligences — people · AI — across any vendor."
>
  <header>
    <div class="seal">无忌</div>
    <h1 class="wordmark">Wuji Labs</h1>
    <p class="substrate">A substrate for intelligences.</p>
    <p class="scope">people · AI — across any vendor</p>
  </header>

  <nav class="toggle" aria-label="Dimensions">
    <button data-dim="hh">people ↔ people</button>
    <button data-dim="ha">people → AI</button>
    <button data-dim="ah">AI → people</button>
    <button data-dim="aa">AI ↔ AI</button>
    <button data-dim="all" aria-pressed="true">all</button>
  </nav>

  <div class="framings" aria-live="polite">
    <p class="framing" data-for="all">Practices and artifacts, projections of one substrate across four dimensions. <a href="/thesis" class="thesis-pointer">Read the founding thesis →</a></p>
    <p class="framing" data-for="hh">How humans grow with each other in the AI era — coaching, leadership, communication that doesn’t go away when AI shows up.</p>
    <p class="framing" data-for="ha">How a person engages AI — designing workflows, building the craft of communicating with AI, finding groundedness with these new tools.</p>
    <p class="framing" data-for="ah">How AI shows up as a sovereign peer with its own agency, context, and continuity — because something that’s only a tool can’t choose to help. The structurally distinctive column Wuji Labs operates on.</p>
    <p class="framing" data-for="aa">When intelligences talk to each other — the formal protocol and substrate that lets multiple AIs collaborate as peers, not as subordinated parts.</p>
  </div>

  <section class="cards">
    {cards.map((c) => (
      <article class="card" data-dims={c.dims}>
        <h3><a href={c.href}>{c.title}</a></h3>
        <p>{c.body}</p>
        {c.priceLine && (
          <p class="card-price"><a href={c.priceLine.href}>{c.priceLine.text} →</a></p>
        )}
      </article>
    ))}
  </section>

  <section class="journal">
    <p class="section-label">Recent journal</p>
    {recentJournal.map((j) => (
      <div class="journal-item">
        <a href={j.href}>
          <span class="zh">{j.zh}</span>
          <span class="en">{j.en}</span>
        </a>
        <span class="date">{j.date}</span>
      </div>
    ))}
  </section>

  <section class="signup">
    <p class="section-label util">Subscribe</p>
    <p>New essay every couple of weeks. Bilingual; pick a language tag.</p>
    <form action="/subscribe" method="get">
      <input type="email" name="email" placeholder="you@somewhere.com" aria-label="email" />
      <span class="lang-pref">
        <label><input type="radio" name="lang" value="en" /><span>EN</span></label>
        <label><input type="radio" name="lang" value="zh" /><span>ZH</span></label>
        <label><input type="radio" name="lang" value="both" checked /><span>both</span></label>
      </span>
      <button type="submit">subscribe</button>
    </form>
  </section>

  <footer class="colophon">
    <nav>
      <a href="/thesis">thesis</a><a href="/journal/">journal</a><a href="/about">about</a><a href="/subscribe">subscribe</a><a href="https://github.com/WujiLabs">github</a><a href="mailto:cosimo@wujilabs.dev">contact</a>
    </nav>
    <span>2026. MIT licensed.</span>
  </footer>
</LandingLayout>
