---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en" data-active="all">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="stylesheet" href="/fonts/fonts.css" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" type="image/x-icon" href="/favicon.ico" />
    <style is:global>
      @import '../styles/global.css';
    </style>
    <style is:global>
      body {
        font-size: 17px;
        line-height: 1.7;
        padding: calc(var(--space-unit) * 8) calc(var(--space-unit) * 4);
      }
      .landing {
        max-width: var(--content-width-landing);
        margin: 0 auto;
      }
      .util {
        font-family: 'Source Sans 3', 'Noto Sans SC', sans-serif;
      }

      /* HERO */
      .seal {
        font-family: 'Noto Serif SC', serif;
        color: var(--text-2);
        font-size: 1.25rem;
        margin-bottom: calc(var(--space-unit) * 2);
        letter-spacing: 0.05em;
      }
      .wordmark {
        font-size: 2.5rem;
        font-weight: 600;
        line-height: 1.1;
        margin-bottom: calc(var(--space-unit) * 2);
      }
      .substrate {
        font-size: 1.25rem;
        color: var(--text);
        margin-bottom: calc(var(--space-unit) * 1);
      }
      .scope {
        font-family: 'Source Sans 3', sans-serif;
        color: var(--text-2);
        font-size: 0.95rem;
        margin-bottom: calc(var(--space-unit) * 8);
      }

      /* TOGGLE */
      .toggle {
        display: flex;
        flex-wrap: wrap;
        gap: calc(var(--space-unit) * 3);
        margin-bottom: calc(var(--space-unit) * 3);
        padding-bottom: calc(var(--space-unit) * 3);
        border-bottom: 1px solid var(--rule);
        font-family: 'Source Sans 3', 'Noto Sans SC', sans-serif;
        font-size: 0.9rem;
      }
      .toggle button {
        background: none;
        border: none;
        color: var(--text-2);
        cursor: pointer;
        padding: calc(var(--space-unit) * 1) 0;
        font: inherit;
        border-bottom: 1px solid transparent;
        transition: color 120ms;
      }
      .toggle button:hover { color: var(--text); }
      .toggle button:focus-visible {
        outline: 2px solid var(--link);
        outline-offset: 4px;
      }
      .toggle button[aria-pressed="true"] {
        color: var(--text);
        border-bottom-color: var(--text);
      }

      /* DIM FRAMINGS — persistent subtitle under toggle row.
         Reserved min-height prevents cards jittering when switching dims. */
      .framings {
        min-height: 5.5em;
        margin-bottom: calc(var(--space-unit) * 4);
        max-width: 60ch;
      }
      .framing {
        display: none;
        color: var(--text-2);
        font-size: 0.95rem;
        line-height: 1.55;
        font-style: italic;
      }
      [data-active="all"] .framing[data-for="all"],
      [data-active="hh"] .framing[data-for="hh"],
      [data-active="ha"] .framing[data-for="ha"],
      [data-active="ah"] .framing[data-for="ah"],
      [data-active="aa"] .framing[data-for="aa"] {
        display: block;
      }

      /* CARDS — no chips. Dim membership signalled only by which cards stay lit. */
      .cards {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: calc(var(--space-unit) * 6) calc(var(--space-unit) * 6);
        margin-bottom: calc(var(--space-unit) * 10);
      }
      /* Flex column so .card-price can margin-top:auto and anchor to the
         bottom of the card. Grid rows already stretch siblings to equal
         heights, so two cards on the same row (Wuji Labs Inc + CEC) get
         vertically-aligned price sub-lines regardless of body length. */
      .card { display: flex; flex-direction: column; transition: opacity 200ms; }
      .card.is-dim {
        opacity: 0.22;
        pointer-events: none;
      }
      .card h3 {
        font-size: 1.15rem;
        font-weight: 600;
        margin-bottom: calc(var(--space-unit) * 1.5);
        line-height: 1.3;
      }
      .card h3 a { color: var(--text); text-decoration: none; }
      .card h3 a:hover { color: var(--link); }
      .card p {
        color: var(--text-2);
        font-size: 0.96rem;
        line-height: 1.6;
        margin-bottom: 0;
      }
      /* Quiet pricing pointer on household-practice cards. Pushed to the
         bottom of the card via margin-top:auto so two cards in the same
         grid row align their price baselines regardless of body length. */
      .card-price {
        font-family: 'Source Sans 3', 'Noto Sans SC', sans-serif;
        font-size: 0.85rem;
        color: var(--text-3);
        margin: 0;
        padding-top: calc(var(--space-unit) * 1.5);
        margin-top: auto;
      }
      .card-price a {
        color: inherit;
        text-decoration: none;
        border-bottom: 1px solid var(--rule);
        padding-bottom: 1px;
      }
      .card-price a:hover {
        color: var(--link);
        border-bottom-color: var(--link);
      }

      /* Thesis pointer appended to the "all" framing. Drops the framing's
         italic so it reads as a navigation link, not essay prose. */
      .thesis-pointer {
        font-style: normal;
        color: var(--text-2);
        text-decoration: none;
        border-bottom: 1px solid var(--rule);
        padding-bottom: 1px;
      }
      .thesis-pointer:hover {
        color: var(--link);
        border-bottom-color: var(--link);
      }

      /* JOURNAL */
      .journal {
        border-top: 1px solid var(--rule);
        padding-top: calc(var(--space-unit) * 4);
        margin-bottom: calc(var(--space-unit) * 6);
      }
      .section-label {
        font-family: 'Source Sans 3', sans-serif;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--text-3);
        margin-bottom: calc(var(--space-unit) * 3);
      }
      .journal-item { margin-bottom: calc(var(--space-unit) * 2.5); }
      .journal-item a { color: var(--text); text-decoration: none; }
      .journal-item a:hover .zh { color: var(--link); }
      .journal-item .zh { display: block; font-family: 'Noto Serif SC', serif; }
      .journal-item .en { display: block; color: var(--text-2); font-size: 0.94rem; }
      .journal-item .date {
        display: inline-block;
        margin-top: calc(var(--space-unit) * 0.5);
        font-family: 'Source Sans 3', sans-serif;
        color: var(--text-3);
        font-size: 0.8rem;
      }

      /* SIGNUP */
      .signup {
        border-top: 1px solid var(--rule);
        padding-top: calc(var(--space-unit) * 4);
        margin-bottom: calc(var(--space-unit) * 6);
      }
      .signup p {
        color: var(--text-2);
        margin-bottom: calc(var(--space-unit) * 2);
        font-size: 0.95rem;
      }
      .signup form {
        display: flex;
        flex-wrap: wrap;
        gap: calc(var(--space-unit) * 1.5);
        align-items: center;
        font-family: 'Source Sans 3', sans-serif;
        font-size: 0.9rem;
      }
      .signup input[type="email"] {
        background: transparent;
        border: 1px solid var(--rule);
        color: var(--text);
        padding: calc(var(--space-unit) * 1.25) calc(var(--space-unit) * 1.5);
        font: inherit;
        min-width: 240px;
      }
      .signup input[type="email"]:focus {
        outline: none;
        border-color: var(--text-2);
      }
      .signup .lang-pref {
        display: flex;
        gap: calc(var(--space-unit) * 0.5);
      }
      .signup .lang-pref label {
        color: var(--text-3);
        cursor: pointer;
        padding: 0 calc(var(--space-unit) * 0.75);
      }
      .signup .lang-pref input[type="radio"] { display: none; }
      .signup .lang-pref input[type="radio"]:checked + span { color: var(--text); }
      .signup button[type="submit"] {
        background: transparent;
        border: 1px solid var(--text-2);
        color: var(--text);
        padding: calc(var(--space-unit) * 1.25) calc(var(--space-unit) * 2);
        font: inherit;
        cursor: pointer;
      }
      .signup button[type="submit"]:hover { border-color: var(--text); }

      /* FOOTER */
      footer.colophon {
        border-top: 1px solid var(--rule);
        padding-top: calc(var(--space-unit) * 3);
        font-family: 'Source Sans 3', sans-serif;
        font-size: 0.85rem;
        color: var(--text-3);
        display: flex;
        flex-wrap: wrap;
        gap: calc(var(--space-unit) * 1.5);
        align-items: baseline;
        justify-content: space-between;
      }
      footer.colophon nav a {
        color: var(--text-2);
        text-decoration: none;
        padding: 0 calc(var(--space-unit) * 0.5);
      }
      footer.colophon nav a:hover { color: var(--text); }

      /* MOBILE */
      @media (max-width: 720px) {
        body { padding: calc(var(--space-unit) * 4) calc(var(--space-unit) * 2.5); }
        .wordmark { font-size: 2rem; }
        .cards { grid-template-columns: 1fr; gap: calc(var(--space-unit) * 5); }
        .toggle { gap: calc(var(--space-unit) * 2); font-size: 0.85rem; }
        /* 44px+ touch targets per WCAG 2.5.5 */
        .toggle button {
          padding: calc(var(--space-unit) * 1.5) calc(var(--space-unit) * 0.5);
          min-height: 44px;
        }
        .signup button[type="submit"] {
          padding: calc(var(--space-unit) * 1.75) calc(var(--space-unit) * 2.5);
          min-height: 44px;
        }
        .signup input[type="email"] { min-height: 44px; }
        .signup .lang-pref label {
          min-height: 44px;
          display: inline-flex;
          align-items: center;
        }
      }
    </style>
  </head>
  <body>
    <main class="landing">
      <slot />
    </main>
    <script>
      // Toggle: clicking a dim button (a) sets data-active on <html> so the
      // matching framing becomes visible and off-dim cards drop to 22%
      // opacity; (b) updates aria-pressed on buttons. "all" restores.
      // Layout preserved (no reflow). Degrades cleanly without JS:
      // default state = "all", all cards visible, no toggle interaction.
      const buttons = document.querySelectorAll<HTMLButtonElement>('.toggle button');
      const cards = document.querySelectorAll<HTMLElement>('.card');
      buttons.forEach((btn) => {
        btn.addEventListener('click', () => {
          const dim = btn.dataset.dim || 'all';
          buttons.forEach((b) => b.setAttribute('aria-pressed', String(b === btn)));
          document.documentElement.dataset.active = dim;
          cards.forEach((c) => {
            const dims = (c.dataset.dims || '').split(/\s+/);
            const lit = dim === 'all' || dims.includes(dim);
            c.classList.toggle('is-dim', !lit);
          });
        });
      });
    </script>
  </body>
</html>
