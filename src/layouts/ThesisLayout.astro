---
interface Props {
  title: string;
  description: string;
  lang: string;
}

const { title, description, lang } = Astro.props;
const isZh = lang === 'zh-Hans';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;0,8..60,700;1,8..60,400&family=Noto+Serif+SC:wght@400;600;700&family=Source+Sans+3:wght@400;600&family=Noto+Sans+SC:wght@400&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" type="image/x-icon" href="/favicon.ico" />
    <style is:global>
      @import '../styles/global.css';
    </style>
    <style is:global define:vars={{ bodySize: isZh ? '17px' : '18px', lineHeight: isZh ? '1.9' : '1.8' }}>
      body {
        background: var(--thesis-bg);
        color: var(--thesis-text);
        font-size: var(--bodySize);
        line-height: var(--lineHeight);
        padding: calc(var(--space-unit) * 6) calc(var(--space-unit) * 3);
      }
      .thesis {
        max-width: var(--content-width-thesis);
        margin: 0 auto;
      }
      .thesis h1 {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: calc(var(--space-unit) * 2);
        line-height: 1.3;
      }
      .thesis h2 {
        font-size: 1.5rem;
        font-weight: 600;
        margin-top: calc(var(--space-unit) * 5);
        margin-bottom: calc(var(--space-unit) * 2);
      }
      .thesis h3 {
        font-size: 1.2rem;
        font-weight: 600;
        margin-top: calc(var(--space-unit) * 4);
        margin-bottom: calc(var(--space-unit) * 1.5);
      }
      .thesis p {
        margin-bottom: calc(var(--space-unit) * 2);
      }
      .thesis a {
        color: var(--thesis-link);
      }
      .thesis a:hover {
        text-decoration: none;
      }
      .thesis blockquote {
        border-left: 3px solid var(--thesis-border);
        padding-left: calc(var(--space-unit) * 3);
        margin: calc(var(--space-unit) * 3) 0;
        font-style: italic;
        color: var(--thesis-text-secondary);
      }
      .thesis code {
        background: rgba(0, 0, 0, 0.05);
        padding: 2px 6px;
        border-radius: 3px;
        font-size: 0.9em;
      }
      @media (prefers-color-scheme: dark) {
        .thesis code {
          background: rgba(255, 255, 255, 0.08);
        }
      }
      .thesis hr {
        border: none;
        border-top: 1px solid var(--thesis-border);
        margin: calc(var(--space-unit) * 5) 0;
      }
      .thesis ul, .thesis ol {
        padding-left: calc(var(--space-unit) * 3);
        margin-bottom: calc(var(--space-unit) * 2);
      }
      .thesis li {
        margin-bottom: calc(var(--space-unit) * 1);
      }
      .thesis strong {
        font-weight: 600;
      }
      .meta {
        font-family: 'Source Sans 3', 'Noto Sans SC', sans-serif;
        color: var(--thesis-text-secondary);
        font-size: 0.9rem;
        margin-bottom: calc(var(--space-unit) * 5);
      }
      .back-link {
        display: inline-block;
        margin-top: calc(var(--space-unit) * 6);
        font-family: 'Source Sans 3', 'Noto Sans SC', sans-serif;
        font-size: 0.9rem;
        color: var(--thesis-text-secondary);
        text-decoration: none;
      }
      .back-link:hover {
        color: var(--thesis-link);
      }

      @media (max-width: 480px) {
        body {
          font-size: 16px;
          padding: calc(var(--space-unit) * 3) calc(var(--space-unit) * 2);
        }
        .thesis h1 {
          font-size: 1.6rem;
        }
      }
    </style>
  </head>
  <body>
    <article class="thesis">
      <slot />
      <a href="/" class="back-link">← wujilabs.dev</a>
    </article>
  </body>
</html>
